# Environment settings ("development" | "staging" | "production")
ENV=development

# Server API Key (required in staging/production, optional in development)
API_KEY=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "azure"  → AzureChatOpenAI
# "openai" → ChatOpenAI
LLM_PROVIDER=azure

# ── Azure OpenAI — Primary Endpoint ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Azure OpenAI — Secondary / Failover Endpoint ─────────────────────────────
# Optional: populate for regional failover (e.g., Sweden Central)
AZURE_OPENAI_FAILOVER_ENDPOINT=
AZURE_OPENAI_FAILOVER_API_KEY=

# ── OpenAI API (non-Azure fallback) ──────────────────────────────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=mypassword
READONLY_POSTGRES_PASSWORD=readonly_password

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=mypassword
