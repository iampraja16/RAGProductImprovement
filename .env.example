ENV=development
API_KEY=

MODEL_PROVIDER=azure

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_LLM_DEPLOYMENT_NAME=
AZURE_OPENAI_MINI_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBED_MODEL_DEPLOYMENT_NAME=

AZURE_OPENAI_FAILOVER_ENDPOINT=
AZURE_OPENAI_FAILOVER_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

EMBEDDING_DIMENSION=1536

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=emr_documents

POSTGRES_URL=postgresql://myuser:mypassword@localhost:5432/emr_db
READONLY_POSTGRES_URL=postgresql://readonly_user:readonly_password@localhost:5432/emr_db
SQL_ROW_LIMIT=100
DATAFRAME_MARKDOWN_LIMIT=20
DATAFRAME_SUMMARY_TOKEN_LIMIT=1000

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

NEO4J_VECTOR_INDEX_SYMPTOM=symptom-embeddings
NEO4J_VECTOR_INDEX_COMMUNITY=community-embeddings
NEO4J_FULLTEXT_INDEX_ENTITY=entity-names

COMMUNITY_GAMMA=1.0
COMMUNITY_THETA=0.01
COMMUNITY_RELATIONSHIP_TYPES=["EXHIBITED","CAUSED_BY","RESOLVED_BY","INVOLVES_PART","BELONGS_TO","MENTIONS","ON_MACHINE"]

REDIS_URL=redis://localhost:6379/0

EVAL_MODEL_FAMILY=gpt-4o

OTEL_ENABLED=false
OTEL_SERVICE_NAME=emr-fault-analyzer
OTEL_EXPORTER_ENDPOINT=

DATA_DIR=data
EMR_FILE_NAME=Dashboard EMR(report1776669858353).csv
EMR_SHEET_NAME=report1776669858353